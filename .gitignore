# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.env
.env.local
.env.*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

dev-dist/
.claude/

# OSM collected raw data (regenerate via: node scripts/collect-bd-locations.mjs)
data/collected/
# Processed intermediate data (regenerate via: node scripts/process-bd-locations.mjs)
data/generated/

# Dev screenshots and AI tooling artifacts — never commit these
.playwright-mcp/
.agent/
.gemini/
scroll-screenshots/
# Root-level and misc PNG screenshots (Playwright/manual testing)
# Exception: public/ and intercity/public/ contain real app assets
*.png
!public/*.png
!public/buses-image/*.png
!public/images/**/*.png
!intercity/public/*.png
!intercity-route-finder/public/*.png

# Secret management scripts — run locally, never commit
update-smtp-secret.cjs
setup-secrets.cjs
setup-koyjabo-core-secrets.cjs

# Sensitive local transport dataset files
public/bd-locations.json
public/data/*.json
data/bangladesh-intercity-routes.json
data/comprehensive-bangladesh-intercity-routes.json

# Local intercity public data mirrors (should not be committed)
intercity/public/data/*.json

# Backup files
*.backup

# Dead projects that should not be in this repo
intercity-route-finder/

# User PII, device tracking, and search history — must not be in git
# These are community data store files managed by the Cloudflare proxy
data/users/
data/devices/
data/history/
data/avatars/
data/results/
data/advanced-qa.raw.json
