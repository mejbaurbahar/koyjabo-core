{
    "redirects": [
        {
            "source": "/about.html",
            "destination": "/about",
            "permanent": true
        },
        {
            "source": "/contact.html",
            "destination": "/contact",
            "permanent": true
        },
        {
            "source": "/privacy-policy.html",
            "destination": "/privacy",
            "permanent": true
        },
        {
            "source": "/terms-of-service.html",
            "destination": "/terms",
            "permanent": true
        },
        {
            "source": "/faq.html",
            "destination": "/faq",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/ads-proxy",
            "destination": "https://srv.adstxtmanager.com/19390/koyjabo.com"
        }
    ],
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "devCommand": "npm run dev",
    "installCommand": "npm install",
    "framework": "vite",
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)\\.(?:jpg|jpeg|png|gif|webp|svg|ico)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)\\.(?:js|css)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/sw.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*)\\.html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=300, must-revalidate"
                }
            ]
        },
        {
            "source": "/api/gh",
            "headers": [
                { "key": "Cache-Control", "value": "no-store, no-cache" },
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "index, follow"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=(self)"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=31536000; includeSubDomains; preload"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://pagead2.googlesyndication.com https://partner.googleadservices.com https://tpc.googlesyndication.com https://*.doubleclick.net https://*.google.com https://*.googletagmanager.com https://*.googletagservices.com https://www.google-analytics.com https://ezoic.net https://*.ezoic.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://api.ipify.org; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; object-src 'none'; base-uri 'self';"
                }
            ]
        }
    ],
    "routes": [
        {
            "src": "/intercity$",
            "dest": "/intercity/index.html"
        },
        {
            "src": "/intercity/assets/(.*)",
            "dest": "/intercity/assets/$1"
        },
        {
            "src": "/intercity/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf))",
            "dest": "/intercity/$1"
        },
        {
            "src": "/intercity/(.*)",
            "dest": "/intercity/index.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "git": {
        "deploymentEnabled": {
            "main": true,
            "gh-pages": false
        }
    }
}
