# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ── Firebase (Google OAuth) ───────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
# Enable Authentication → Sign-in method → Google
# Copy config from Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# ── Auth System (Cloudflare Worker proxy) ────────────────────────────────────
# All auth + community writes go through the Cloudflare Worker — repo names,
# the GitHub PAT, and the bcrypt hash never reach the browser. Configure the
# worker via `wrangler secret put` (see cloudflare-worker.js header for the
# variable list: GH_TOKEN, DATA_TOKEN, TURNSTILE_SECRET, JWT_SECRET, …).
#
# IMPORTANT: never add VITE_GITHUB_TOKEN — Vite inlines every VITE_-prefixed
# variable into the JS bundle, so anything pasted here ships to every visitor.

# Worker URL override (defaults to https://koyjabo-auth-proxy.mejbaur-bahar.workers.dev)
VITE_API_PROXY=

# Backend API URL (optional - defaults to production)
VITE_BACKEND_URL=

# Gemini API Keys for AI features (supports key rotation for better load distribution)
# Get your keys from: https://aistudio.google.com/app/apikey
# You can use 1 to 5 keys (use GEMINI_API_KEY for primary key, or all 5 for rotation)

# Primary key (used if only one key is available)
GEMINI_API_KEY=your_primary_gemini_api_key_here

# Additional keys for rotation (optional but recommended)
GEMINI_API_KEY_1=your_first_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
GEMINI_API_KEY_3=your_third_gemini_api_key_here
GEMINI_API_KEY_4=your_fourth_gemini_api_key_here
GEMINI_API_KEY_5=your_fifth_gemini_api_key_here

# TomTom API Keys for real-time traffic data (optional)
# Get your keys from: https://developer.tomtom.com/
# These are used for live traffic visualization on the map
VITE_TOMTOM_API_KEY_1=your_tomtom_api_key_1_here
VITE_TOMTOM_API_KEY_2=your_tomtom_api_key_2_here

