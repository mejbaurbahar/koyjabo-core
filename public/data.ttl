    schema:url <https://linkedin.com/in/mejbaur/> .

# --- Metro Rail ---

kj:MRTLine6
    a schema:TrainRoute ;
    schema:name "Dhaka MRT Line-6 (Uttara North – Motijheel)" ;
    schema:description "Dhaka's urban metro rail. 20.1 km, 16 stations from Uttara North to Motijheel." ;
    schema:operatedBy kj:DMTCL ;
    schema:departureStation kj:UttaraNorthStation ;
    schema:arrivalStation kj:MotijheelStation ;
    kj:lengthKm "20.1"^^xsd:decimal ;
    kj:fareMinBDT "20"^^xsd:integer ;
    kj:fareMaxBDT "100"^^xsd:integer ;
    kj:operatingHoursWeekday "07:00–20:00" ;
    kj:operatingHoursFriday "08:00–20:00" ;
    kj:peakFrequencyMin "8"^^xsd:integer ;
    kj:ticketingOptions "Single-journey token or Rapid Pass RFID card" ;
    schema:url <https://koyjabo.com/#metro> .

kj:DMTCL
    a schema:Organization ;
    schema:name "Dhaka Mass Transit Company Limited" ;
    schema:alternateName "DMTCL" .

kj:UttaraNorthStation
    a schema:TrainStation ;
    schema:name "Uttara North MRT Station" ;
    geo:lat "23.8715"^^xsd:decimal ;
    geo:long "90.3985"^^xsd:decimal .

kj:MotijheelStation
    a schema:TrainStation ;
    schema:name "Motijheel MRT Station" ;
    geo:lat "23.7279"^^xsd:decimal ;
    geo:long "90.4170"^^xsd:decimal .

