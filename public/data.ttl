<https://koyjabo.com>
    a schema:WebSite ;
    schema:name "KoyJabo" ;
    schema:alternateName "কই যাবো" ;
    schema:description "Bangladesh's leading free travel and transport guide. 200+ Dhaka bus routes, Metro Rail (MRT Line-6), intercity buses, trains, river ferries, and domestic flights." ;
    schema:url <https://koyjabo.com> ;
    schema:inLanguage "en", "bn" ;
    schema:author kj:MejbaurBaharFagun ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
