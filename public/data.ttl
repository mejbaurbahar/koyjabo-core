# --- River Launches ---

kj:DhakaBarisalLaunch
    a kj:RiverLaunch ;
    schema:name "Dhaka – Barisal Night Launch" ;
    schema:description "Overnight river ferry from Sadarghat, Dhaka to Barisal. Popular budget travel option on Bangladesh's inland waterways." ;
    schema:operatedBy kj:BIWTC ;
    schema:departureStation kj:SadarghatTerminal ;
    kj:durationHrs "8"^^xsd:decimal ;
    kj:fareMinBDT "150"^^xsd:integer ;
    kj:fareMaxBDT "2000"^^xsd:integer ;
    schema:url <https://koyjabo.com/intercity#launch> .

